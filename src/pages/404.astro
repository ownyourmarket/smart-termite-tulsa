---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found | Smart Termite Tulsa" description="The page you were looking for could not be found.">
  <section class="hero">
    <div class="container">
      <h1>That page wandered off.</h1>
      <p class="sub">We couldn't find what you were looking for. Here are a few places to head next:</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/" class="btn btn-primary">Home</a>
        <a href="/contact" class="btn btn-secondary">Request Inspection</a>
        <a href="/tulsa-termite-warning-signs" class="btn btn-secondary">Warning Signs</a>
      </div>
    </div>
  </section>
</BaseLayout>
