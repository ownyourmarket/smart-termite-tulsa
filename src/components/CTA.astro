---
const {
  heading = 'Not sure if it is termites?',
  sub = 'Request an inspection and get clear next steps from a local professional.',
  primary = { href: '/contact', label: 'Request Inspection' },
  secondary = { href: '/tulsa-termite-warning-signs', label: 'See Warning Signs' },
} = Astro.props;
---
<section>
  <div class="container">
    <div class="cta-banner">
      <h2>{heading}</h2>
      <p>{sub}</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href={primary.href} class="btn btn-primary btn-lg" data-event="cta_click" data-lead-type="request_inspection">{primary.label}</a>
        <a href={secondary.href} class="btn btn-outline btn-lg" data-event="cta_click">{secondary.label}</a>
      </div>
    </div>
  </div>
</section>
