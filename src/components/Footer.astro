---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="logo" style="font-size:1.2rem;margin-bottom:10px;">Smart Termite Tulsa</div>
        <p class="muted" style="font-size:0.9rem;">Local termite education and inspection requests for Tulsa-area homeowners. We help you spot warning signs early and connect you with professional next steps.</p>
        <p style="margin-top:14px;">
          <!-- TODO: Replace with final business / call-tracking number -->
          <a href="tel:+19185550199" data-event="call_click" data-lead-type="phone">Call (918) 555-0199</a><br/>
          <!-- TODO: Replace with final business email -->
          <a href="mailto:hello@smarttermitetulsa.com" data-event="email_click">hello@smarttermitetulsa.com</a>
        </p>
      </div>
      <div>
        <h4>Pages</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/termite-inspection-tulsa">Inspection</a></li>
          <li><a href="/termite-treatment-options">Treatment</a></li>
          <li><a href="/termite-prevention-guide">Prevention</a></li>
          <li><a href="/tulsa-termite-warning-signs">Warning Signs</a></li>
          <li><a href="/termite-warning-signs-checklist">Checklist</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4>Service Areas</h4>
        <ul>
          <li><a href="/service-areas">Tulsa</a></li>
          <li><a href="/service-areas">Broken Arrow</a></li>
          <li><a href="/service-areas">Jenks</a></li>
          <li><a href="/service-areas">Bixby</a></li>
          <li><a href="/service-areas">Owasso</a></li>
          <li><a href="/service-areas">Sand Springs</a></li>
          <li><a href="/service-areas">Sapulpa</a></li>
          <li><a href="/service-areas">Glenpool</a></li>
          <li><a href="/service-areas">Claremore</a></li>
          <li><a href="/service-areas">Catoosa</a></li>
        </ul>
      </div>
      <div>
        <h4>Request an Inspection</h4>
